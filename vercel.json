{
    "redirects": [
        {
            "source": "/",
            "destination": "/MVP",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/MVP(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}